rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function myEmail() {
      return request.auth.token.email.lower();
    }

    function eventDoc(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventMember(eventId) {
      return signedIn() && myEmail() in eventDoc(eventId).data.memberEmails;
    }

    function isEventOrganizer(eventId) {
      return signedIn() && myEmail() in eventDoc(eventId).data.organizerEmails;
    }

    function isEventRoomCoordinator(eventId) {
      // Returns true if the document has a roomEmails field and the user is in it.
      let docData = eventDoc(eventId).data;
      return signedIn() && myEmail() in docData.get('roomEmails', []);
    }

    function isGuestSelf(guestData) {
      return signedIn() && (
        (guestData.get('email', '') != '' && myEmail() == guestData.get('email', '').lower()) ||
        (guestData.get('contact', '') != '' && myEmail() == guestData.get('contact', '').lower())
      );
    }

    function publicInviteHasIdentifier() {
      return (request.resource.data.email is string && request.resource.data.email != '') ||
        (request.resource.data.contact is string && request.resource.data.contact != '');
    }

    function isPublicInviteGuestPayload() {
      let eventId = request.resource.data.eventId;
      return eventId is string &&
        eventDoc(eventId).data.name is string &&
        request.resource.data.keys().hasOnly([
          'eventId',
          'first',
          'last',
          'contact',
          'email',
          'party',
          'rsvp',
          'notes',
          'dietPreference',
          'table',
          'roomAssignments',
          'roomRequestType',
          'requestedRoomCount',
          'requestedStayCount',
          'roomRequestNote',
          'roomRequestStatus',
          'source',
          'createdAt'
        ]) &&
        request.resource.data.first is string &&
        request.resource.data.first.size() > 0 &&
        request.resource.data.first.size() <= 120 &&
        (!('contact' in request.resource.data) || request.resource.data.contact is string) &&
        (!('email' in request.resource.data) || request.resource.data.email is string) &&
        publicInviteHasIdentifier() &&
        (!('notes' in request.resource.data) || request.resource.data.notes is string) &&
        (!('dietPreference' in request.resource.data) || request.resource.data.dietPreference in ['veg', 'non-veg']) &&
        request.resource.data.party == 1 &&
        request.resource.data.rsvp == 'pending' &&
        request.resource.data.table == '' &&
        request.resource.data.roomAssignments is list &&
        request.resource.data.roomAssignments.size() == 0 &&
        request.resource.data.requestedRoomCount == 1 &&
        request.resource.data.requestedStayCount == 1 &&
        request.resource.data.roomRequestNote == '' &&
        request.resource.data.roomRequestType in ['needs_room', 'no_room_needed'] &&
        request.resource.data.roomRequestStatus in ['pending', 'fulfilled'] &&
        request.resource.data.source == 'public_invite' &&
        request.resource.data.createdAt is int;
    }

    function isPublicInviteGuestUpdate() {
      return resource.data.source == 'public_invite' &&
        request.resource.data.eventId == resource.data.eventId &&
        (
          (request.resource.data.email is string && request.resource.data.email != '' && request.resource.data.email == resource.data.email) ||
          (request.resource.data.contact is string && request.resource.data.contact != '' && request.resource.data.contact == resource.data.contact)
        ) &&
        isPublicInviteGuestPayload();
    }

    match /events/{eventId} {
      allow read: if signedIn() && (myEmail() in resource.data.memberEmails || myEmail() in resource.data.get('guestEmails', []));
      allow create: if signedIn()
        && myEmail() in request.resource.data.memberEmails
        && myEmail() in request.resource.data.organizerEmails;
      allow update: if isEventOrganizer(eventId) || isEventRoomCoordinator(eventId) || (!('roomEmails' in resource.data) && isEventMember(eventId)) || (
        // Allow updating guestEmails array natively if pushing guest updates
        !isEventOrganizer(eventId) && !isEventRoomCoordinator(eventId) && isEventMember(eventId) && request.resource.data.guestEmails != null
      );
      allow delete: if isEventOrganizer(eventId);
    }

    match /guests/{guestId} {
      allow read: if signedIn() && (isEventMember(resource.data.eventId) || isGuestSelf(resource.data));
      allow update: if
        isPublicInviteGuestUpdate() ||
        (signedIn() && (
        isEventMember(resource.data.eventId) ||
        (
          isGuestSelf(resource.data) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'roomRequestType',
            'requestedRoomCount',
            'requestedStayCount',
            'roomRequestNote',
            'roomRequestStatus',
            'roomRequestUpdatedAt'
          ]) &&
          (request.resource.data.roomRequestStatus == 'pending' || request.resource.data.roomRequestStatus == 'none')
        ) ||
        (
          isGuestSelf(resource.data) &&
          eventDoc(resource.data.eventId).data.get('feedbackEnabled', false) == true &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'feedbackFoodRating',
            'feedbackEventRating',
            'feedbackRoomRating',
            'feedbackMessage',
            'feedbackUpdatedAt'
          ])
        ) ||
        (
          isGuestSelf(resource.data) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'foodMenuLikes',
            'foodMenuLikesUpdatedAt'
          ])
        )
      ));
      allow delete: if signedIn() && isEventMember(resource.data.eventId);
      allow create: if (signedIn() && isEventMember(request.resource.data.eventId)) || isPublicInviteGuestPayload();
    }

    match /gifts/{giftId} {
      allow read, update, delete: if signedIn() && isEventMember(resource.data.eventId);
      allow create: if signedIn() && isEventMember(request.resource.data.eventId);
    }

    match /publicInvites/{inviteKey} {
      allow read: if resource.data.enabled == true;
      allow create: if signedIn() && isEventOrganizer(request.resource.data.eventId);
      allow update: if signedIn() && isEventOrganizer(resource.data.eventId);
      allow delete: if signedIn() && isEventOrganizer(resource.data.eventId);
    }

    match /masterGuestShares/{shareId} {
      allow create: if signedIn()
        && request.resource.data.senderEmail is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.senderEmail.lower() == myEmail();

      allow read: if signedIn() && (
        resource.data.senderEmail.lower() == myEmail() ||
        resource.data.recipientEmail.lower() == myEmail()
      );

      allow update: if signedIn() && (
        resource.data.senderEmail.lower() == myEmail() ||
        resource.data.recipientEmail.lower() == myEmail()
      );

      allow delete: if signedIn() && (
        resource.data.senderEmail.lower() == myEmail() ||
        resource.data.recipientEmail.lower() == myEmail()
      );
    }
  }
}
